<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_month_picker_header"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="14dp"
        android:paddingTop="10dp">

        <View
            android:layout_width="44dp"
            android:layout_height="4dp"
            android:background="#99B8D8"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/month_picker_report_title"
            android:textColor="#0D47A1"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPreviewMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/month_picker_preview_placeholder"
            android:textColor="#2F5B95"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCurrentMonth"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="@string/current_month"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:strokeColor="#90CAF9"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPreviousMonth"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="@string/previous_month"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:strokeColor="#90CAF9"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp">

        <NumberPicker
            android:id="@+id/npMonth"
            android:layout_width="0dp"
            android:layout_height="170dp"
            android:layout_weight="1" />

        <NumberPicker
            android:id="@+id/npYear"
            android:layout_width="0dp"
            android:layout_height="170dp"
            android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelMonthPicker"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="@string/cancel"
            android:textAllCaps="false"
            app:strokeColor="#B0BEC5"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyMonthPicker"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="@string/apply"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            app:iconGravity="textStart" />
    </LinearLayout>

</LinearLayout>
