<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="7dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeColor="#E3EAF2"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPhong"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/item_invoice_room_sample"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvRibbonStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_month_filter_chip"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/item_invoice_status_unreported"
                android:textColor="#0D47A1"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvAmountTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/invoice_total_amount_placeholder"
            android:textColor="#1B5E20"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvTenantName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/item_invoice_tenant_info_sample"
            android:textColor="#37474F"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvReportDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/item_invoice_month_sample"
            android:textColor="#607D8B"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvPriceMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/item_invoice_price_month_sample"
            android:textColor="#607D8B"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvExtraFeeSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/invoice_extra_fee_summary_placeholder"
            android:textColor="#455A64"
            android:textSize="12sp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvMeterSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/invoice_meter_summary_placeholder"
            android:textColor="#455A64"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvOwnerNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#FFF3E0"
            android:padding="8dp"
            android:textColor="#E65100"
            android:textSize="13sp"
            android:textStyle="italic"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMainAction"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:minHeight="0dp"
            android:text="@string/item_invoice_action_report_fee"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:backgroundTint="#1565C0"
            app:cornerRadius="10dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
