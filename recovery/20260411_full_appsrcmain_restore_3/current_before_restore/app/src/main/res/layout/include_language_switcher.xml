<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/languageSwitchContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@android:color/transparent"
    android:gravity="center"
    android:elevation="0dp"
    android:paddingHorizontal="4dp"
    android:paddingVertical="4dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLangEn"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="🇬🇧"
        android:textSize="19sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        app:backgroundTint="@android:color/transparent"
        app:strokeWidth="0dp"
        app:rippleColor="@color/primary_alpha"
        android:contentDescription="@string/english_language" />

    <Space
        android:layout_width="3dp"
        android:layout_height="1dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLangVi"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="🇻🇳"
        android:textSize="19sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        app:backgroundTint="@android:color/transparent"
        app:strokeWidth="0dp"
        app:rippleColor="@color/primary_alpha"
        android:contentDescription="@string/vietnamese_language" />
</LinearLayout>
