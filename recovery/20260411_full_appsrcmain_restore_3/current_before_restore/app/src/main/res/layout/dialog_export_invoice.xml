<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/white">

    <TextView
        android:id="@+id/tvBillTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/export_invoice_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvBillDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/export_invoice_details_placeholder"
        android:textSize="15sp"
        android:textColor="#424242"
        android:lineSpacingExtra="6dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvBillTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/export_invoice_total_placeholder"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1B5E20"
        android:gravity="end"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invoice_owner_note_edit"
            app:backgroundTint="#F5F5F5"
            android:textColor="#424242"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconTint="#424242"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPaymentHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/payment_history"
            app:backgroundTint="#E8F5E9"
            android:textColor="#388E3C"
            app:iconTint="#388E3C"
            app:icon="@android:drawable/ic_menu_recent_history"
            android:layout_marginTop="8dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/close"
            android:layout_marginTop="8dp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

</LinearLayout>