<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F3F3">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitleLine1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contract_header_title"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvTitleLine2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Pháp lý (Legal Status) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvStatusRule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8F5E9"
                app:strokeWidth="1dp"
                app:strokeColor="#81C784">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="#388E3C" />

                    <TextView
                        android:id="@+id/tvStatusRuleText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Hợp đồng đã được ký kết và khóa lại thành công. Khách thuê và chủ nhà đã xác nhận."
                        android:textColor="#2E7D32"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- UI section note -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E3E3E3"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contract_form_number_required"
                        android:textStyle="bold"
                        android:textColor="#212121"/>
                    <EditText
                        android:id="@+id/etSoHopDong"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_disabled"
                        android:enabled="false"
                        android:paddingHorizontal="14dp"
                        android:inputType="text"
                        android:textColor="#212121"/>

                    <!-- UI section note -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/contract_form_customer_name_required"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etTenKhach"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded"
                                android:paddingHorizontal="14dp"
                                android:inputType="textPersonName"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/contract_form_phone_required"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etDienThoai"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded"
                                android:paddingHorizontal="14dp"
                                android:inputType="phone"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contract_form_personal_id_required"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginTop="12dp"/>
                    <EditText
                        android:id="@+id/etCccd"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_rounded"
                        android:paddingHorizontal="14dp"
                        android:inputType="number"/>

                    <!-- UI section note -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/contract_form_id_front"
                                    android:textColor="#666666"/>
                                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                                <ImageView
                                    android:id="@+id/ivEditFront"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/ic_edit"
                                    app:tint="#333333"/>
                            </LinearLayout>
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="120dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded">
                                <ImageView
                                    android:id="@+id/ivFront"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_id_card"
                                    app:tint="#8A8A8A"/>
                            </FrameLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/contract_form_id_back"
                                    android:textColor="#666666"/>
                                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                                <ImageView
                                    android:id="@+id/ivEditBack"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/ic_edit"
                                    app:tint="#333333"/>
                            </LinearLayout>
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="120dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded">
                                <ImageView
                                    android:id="@+id/ivBack"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_id_card"
                                    app:tint="#8A8A8A"/>
                            </FrameLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- UI section note -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/contract_form_room_required"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etPhong"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_disabled"
                                android:enabled="false"
                                android:paddingHorizontal="14dp"
                                android:inputType="text"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/contract_form_member_count_required"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etSoNguoi"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded"
                                android:paddingHorizontal="14dp"
                                android:inputType="number"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- UI section note -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/contract_form_rent_required"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etTienPhong"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_disabled"
                                android:enabled="false"
                                android:paddingHorizontal="14dp"
                                android:inputType="number"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/contract_label_deposit"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etTienCoc"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded"
                                android:paddingHorizontal="14dp"
                                android:inputType="number"/>
                        </LinearLayout>
                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cbShowDeposit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/contract_show_deposit_on_invoice"
                        android:checked="true"/>

                    <!-- UI section note -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/contract_form_signing_date_required"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp">
                                <EditText
                                    android:id="@+id/etNgayKy"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_input_rounded"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="48dp"
                                    android:hint="@string/contract_date_month_year_hint"
                                    android:inputType="none"
                                    android:focusable="false"
                                    android:clickable="true"/>
                                <ImageView
                                    android:id="@+id/ivPickDate"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center_vertical|end"
                                    android:layout_marginEnd="14dp"
                                    android:src="@drawable/ic_calendar"
                                    app:tint="#333333"/>
                            </FrameLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/contract_form_months_required"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etSoThang"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded"
                                android:paddingHorizontal="14dp"
                                android:inputType="number"/>
                        </LinearLayout>
                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cbRemind"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/contract_remind_before_expiry"
                        android:checked="true"/>

                    <TextView
                        android:id="@+id/tvElectricStartLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contract_form_initial_electric_required"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginTop="12dp"/>
                    <EditText
                        android:id="@+id/etChiSoDien"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_rounded"
                        android:paddingHorizontal="14dp"
                        android:inputType="number"/>

                    <TextView
                        android:id="@+id/tvWaterStartLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contract_form_initial_water_required"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginTop="12dp"/>
                    <EditText
                        android:id="@+id/etChiSoNuoc"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_rounded"
                        android:paddingHorizontal="14dp"
                        android:inputType="number"/>

                    <!-- UI section note -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutParkingService"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">
                        <CheckBox
                            android:id="@+id/cbGuiXe"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/parking_service_label"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/llSoXe"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <LinearLayout
                            android:id="@+id/llSoXe"
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/contract_form_vehicle_count_required"
                                android:textStyle="bold"
                                android:textColor="#212121"
                                android:layout_gravity="end"/>
                            <EditText
                                android:id="@+id/etSoXe"
                                android:layout_width="match_parent"
                                android:layout_height="46dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_disabled"
                                android:enabled="false"
                                android:paddingHorizontal="14dp"
                                android:inputType="number"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvGuiXePrice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/contract_parking_price_default"
                            android:textColor="#212121"
                            app:layout_constraintStart_toStartOf="@id/cbGuiXe"
                            app:layout_constraintTop_toBottomOf="@id/cbGuiXe"
                            app:layout_constraintEnd_toStartOf="@id/llSoXe"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <CheckBox
                        android:id="@+id/cbInternet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/contract_internet_price_default"
                        android:textStyle="bold"/>

                    <CheckBox
                        android:id="@+id/cbGiatSay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/contract_laundry_price_default"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvExtraFeeOptionsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/contract_extra_fee_options_label"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/llExtraFeeOptions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/note_label"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginTop="12dp"/>
                    <EditText
                        android:id="@+id/etGhiChu"
                        android:layout_width="match_parent"
                        android:layout_height="110dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_rounded"
                        android:padding="14dp"
                        android:gravity="top"
                        android:inputType="textMultiLine"/>

                    <CheckBox
                        android:id="@+id/cbShowNote"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/contract_show_note_on_invoice"
                        android:checked="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contract_billing_reminder_label"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginTop="12dp"/>

                    <RadioGroup
                        android:id="@+id/rgBillingReminder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbRemindStartMonth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/remind_start_month"/>

                        <RadioButton
                            android:id="@+id/rbRemindMidMonth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/remind_mid_month"/>
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- UI section note -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="@string/create_contract"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="10dp"
                app:backgroundTint="#1976D2"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrint"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="@string/print_contract"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:visibility="gone"
                app:cornerRadius="10dp"
                app:backgroundTint="#1976D2"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnd"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="@string/end_contract"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:visibility="gone"
                app:cornerRadius="10dp"
                app:backgroundTint="#D32F2F"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="@string/update_contract"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:visibility="gone"
                app:cornerRadius="10dp"
                app:backgroundTint="#1976D2"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLock"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="Khóa hợp đồng (Ký kết)"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:visibility="gone"
                app:cornerRadius="10dp"
                app:backgroundTint="#4CAF50"/>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

