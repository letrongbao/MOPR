<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Diagonal status ribbon placeholder (can use a simple TextView with rotation or a background) -->
            <TextView
                android:id="@+id/tvRibbonStatus"
                android:layout_width="80dp"
                android:layout_height="20dp"
                android:background="#FFEB3B"
                android:text="Đã báo phí"
                android:textSize="9sp"
                android:textColor="#333333"
                android:gravity="center"
                android:rotation="-45"
                android:layout_marginStart="-25dp"
                android:layout_marginTop="5dp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp">

                <!-- Room Info -->
                <TextView
                    android:id="@+id/tvPhong"
                    android:layout_width="80dp"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="P.101"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginEnd="12dp"/>

                <!-- Details -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTenantName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Người thuê: A Minh - ĐT: 0777888639"
                        android:textSize="12sp"
                        android:textColor="#333333"/>

                    <TextView
                        android:id="@+id/tvPriceMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giá: 2.700.000 đ/tháng"
                        android:textSize="12sp"
                        android:textColor="#333333"
                        android:layout_marginTop="2dp"/>

                    <TextView
                        android:id="@+id/tvReportDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày báo phí: 01/10/2024 18:13:02"
                        android:textSize="11sp"
                        android:textColor="#666666"
                        android:layout_marginTop="2dp"/>

                    <!-- Action Buttons -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewDetails"
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:layout_marginTop="12dp"
                        android:text="Xem danh sách phí đã báo của phòng"
                        android:textAllCaps="false"
                        android:textSize="11sp"
                        app:cornerRadius="6dp"
                        app:backgroundTint="@color/btn_blue_action"
                        android:padding="0dp"
                        android:minHeight="0dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:gravity="end">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnViewInvoice"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Xem phiếu"
                            android:textAllCaps="false"
                            android:textSize="11sp"
                            app:cornerRadius="6dp"
                            app:backgroundTint="@color/btn_blue_action"
                            android:layout_marginEnd="4dp"
                            android:minHeight="0dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCancelInvoice"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Huỷ phiếu"
                            android:textAllCaps="false"
                            android:textSize="11sp"
                            app:cornerRadius="6dp"
                            app:backgroundTint="#333333"
                            android:minHeight="0dp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConfirmPayment"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp"
                        android:text="Xác nhận đã thu phí"
                        android:textAllCaps="false"
                        android:textSize="11sp"
                        app:cornerRadius="6dp"
                        app:backgroundTint="@color/btn_orange"
                        android:minHeight="0dp"/>
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>