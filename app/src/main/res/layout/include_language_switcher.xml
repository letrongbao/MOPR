<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/languageSwitchContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/language_switcher_bg"
    android:gravity="center"
    android:padding="4dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLangEn"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="🇬🇧"
        android:textSize="20sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        app:backgroundTint="@android:color/transparent"
        app:strokeWidth="0dp"
        app:rippleColor="@color/primary_alpha"
        android:contentDescription="@string/english_language" />

    <View
        android:layout_width="1dp"
        android:layout_height="24dp"
        android:layout_margin="4dp"
        android:background="@color/language_switcher_divider" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLangVi"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="🇻🇳"
        android:textSize="20sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        app:backgroundTint="@android:color/transparent"
        app:strokeWidth="0dp"
        app:rippleColor="@color/primary_alpha"
        android:contentDescription="@string/vietnamese_language" />
</LinearLayout>
