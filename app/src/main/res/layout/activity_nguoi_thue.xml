<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            android:background="@color/purple"
            app:title="Danh sách khách thuê"
            app:titleTextColor="@color/white"/>

        <!-- Search bar bên dưới Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="10dp"
            android:background="@color/purple"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etTimKiem"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_rounded"
                android:hint="Nhập SĐT/tên tìm kiếm..."
                android:textSize="13sp"
                android:textColorHint="#AAAAAA"
                android:textColor="#1A1A1A"
                android:paddingHorizontal="14dp"
                android:singleLine="true"
                android:inputType="text"
                android:drawableEnd="@drawable/ic_add"
                android:drawableTint="#888888"/>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Trạng thái rỗng -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Chưa có người thuê\nNhấn + để thêm"
        android:textAlignment="center"
        android:textSize="16sp"
        android:textColor="#999999"
        android:visibility="gone"/>

    <!-- Danh sách chính (Nhóm phòng + Thẻ bài khách) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

    <!-- FAB Thêm người thuê -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabThem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Thêm người thuê"
        app:srcCompat="@drawable/ic_add"
        app:backgroundTint="@color/purple"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>