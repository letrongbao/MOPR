<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/payment_method"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerTransferPaymentMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvTransferAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="--" />

        <LinearLayout
            android:id="@+id/layoutTransferInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <TextView
            android:id="@+id/tvTransferInfoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/transfer_info_colon"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTransferAccountNo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="--" />

        <TextView
            android:id="@+id/tvTransferBankName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="--" />

        <TextView
            android:id="@+id/tvTransferAccountName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="--" />

        <ImageView
            android:id="@+id/imgTransferQr"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:adjustViewBounds="true"
            android:background="#F4F7FB"
            android:contentDescription="@string/qr_transfer"
            android:scaleType="fitCenter"
            android:visibility="gone"
            android:src="@drawable/bg_room_placeholder" />

        <TextView
            android:id="@+id/tvTransferQrEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/transfer_qr_not_configured"
            android:textColor="#666666"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvTransferContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="--" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutTransferProofSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <TextView
            android:id="@+id/tvTransferProofLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/transfer_proof_screenshot_label"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imgTransferProof"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="6dp"
            android:adjustViewBounds="true"
            android:background="#EEEEEE"
            android:contentDescription="@string/transfer_proof_screenshot_label"
            android:scaleType="fitCenter"
            android:src="@drawable/bg_room_placeholder" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickTransferProof"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:text="@string/transfer_proof_pick_image" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTransferNoteLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/note_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etTransferProofNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/transfer_proof_note_hint"
            android:inputType="textMultiLine"
            android:minLines="2" />
    </LinearLayout>
</ScrollView>
