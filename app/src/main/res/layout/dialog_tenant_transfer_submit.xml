<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/transfer_info_colon"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTransferBankInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="--" />

        <TextView
            android:id="@+id/tvTransferContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="--" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/payment_amount_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etTransferAmount"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="numberDecimal"
            android:hint="0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/transfer_proof_screenshot_label"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imgTransferProof"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="6dp"
            android:adjustViewBounds="true"
            android:background="#EEEEEE"
            android:contentDescription="@string/transfer_proof_screenshot_label"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_room_placeholder" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickTransferProof"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:text="@string/transfer_proof_pick_image" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/note_optional"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etTransferProofNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/transfer_proof_note_hint"
            android:inputType="textMultiLine"
            android:minLines="2" />
    </LinearLayout>
</ScrollView>
