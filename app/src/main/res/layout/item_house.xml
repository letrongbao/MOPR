<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header (click to open room list) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerRoot"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@color/primary"
            android:paddingHorizontal="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ivHomeIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/baseline_home_24"
                app:tint="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tvHouseAddr"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/item_house_address_sample"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintStart_toEndOf="@id/ivHomeIcon"
                app:layout_constraintEnd_toStartOf="@id/ivChevron"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <ImageView
                android:id="@+id/ivChevron"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_right"
                app:tint="@color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Manager -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_manager_badge"
                    android:foregroundGravity="center">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_id_card"
                        app:tint="@color/primary"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvHouseName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="@string/item_house_manager_sample"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Bank info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/item_house_bank_info_title"
                android:textStyle="italic"
                android:textSize="13sp"
                android:textColor="@color/text_sub"/>

            <TextView
                android:id="@+id/tvBankInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/item_house_bank_info_sample"
                android:textSize="13sp"
                android:textStyle="italic"
                android:textColor="@color/text_sub"/>

            <!-- Toggle fee table -->
            <LinearLayout
                android:id="@+id/llToggleFees"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/baseline_receipt_24"
                    app:tint="@color/primary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/item_house_view_fee_table"
                    android:textSize="14sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <ImageView
                    android:id="@+id/ivFeesExpand"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_expand_more"
                    app:tint="@color/text_sub"/>
            </LinearLayout>

            <!-- Fee table (collapsed by default) -->
            <LinearLayout
                android:id="@+id/llFeeTable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/item_house_fee_type"
                        android:textSize="13sp"
                        android:textColor="@color/text_sub"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/item_house_fee_unit"
                        android:textSize="13sp"
                        android:textColor="@color/text_sub"
                        android:gravity="center"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/item_house_fee_price"
                        android:textSize="13sp"
                        android:textColor="@color/text_sub"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- Rows -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_electricity" android:textSize="14sp" android:textColor="@color/black"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_unit_kwh" android:textSize="14sp" android:textColor="@color/black" android:gravity="center"/>
                    <TextView android:id="@+id/tvFeeDien" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_value_zero" android:textSize="14sp" android:textColor="@color/black" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_water" android:textSize="14sp" android:textColor="@color/black"/>
                    <TextView android:id="@+id/tvFeeNuocUnit" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_unit_room" android:textSize="14sp" android:textColor="@color/black" android:gravity="center"/>
                    <TextView android:id="@+id/tvFeeNuoc" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_value_zero" android:textSize="14sp" android:textColor="@color/black" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_parking" android:textSize="14sp" android:textColor="@color/black"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_unit_vehicle" android:textSize="14sp" android:textColor="@color/black" android:gravity="center"/>
                    <TextView android:id="@+id/tvFeeXe" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_value_zero" android:textSize="14sp" android:textColor="@color/black" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_internet" android:textSize="14sp" android:textColor="@color/black"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_unit_room" android:textSize="14sp" android:textColor="@color/black" android:gravity="center"/>
                    <TextView android:id="@+id/tvFeeInternet" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_value_zero" android:textSize="14sp" android:textColor="@color/black" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_laundry" android:textSize="14sp" android:textColor="@color/black"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_unit_room" android:textSize="14sp" android:textColor="@color/black" android:gravity="center"/>
                    <TextView android:id="@+id/tvFeeGiatSay" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_value_zero" android:textSize="14sp" android:textColor="@color/black" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_elevator" android:textSize="14sp" android:textColor="@color/black"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_unit_room" android:textSize="14sp" android:textColor="@color/black" android:gravity="center"/>
                    <TextView android:id="@+id/tvFeeThangMay" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_value_zero" android:textSize="14sp" android:textColor="@color/black" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_cable_tv" android:textSize="14sp" android:textColor="@color/black"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_unit_room" android:textSize="14sp" android:textColor="@color/black" android:gravity="center"/>
                    <TextView android:id="@+id/tvFeeTiviCap" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_value_zero" android:textSize="14sp" android:textColor="@color/black" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_garbage" android:textSize="14sp" android:textColor="@color/black"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_unit_room" android:textSize="14sp" android:textColor="@color/black" android:gravity="center"/>
                    <TextView android:id="@+id/tvFeeRac" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_value_zero" android:textSize="14sp" android:textColor="@color/black" android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_service" android:textSize="14sp" android:textColor="@color/black"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_unit_room" android:textSize="14sp" android:textColor="@color/black" android:gravity="center"/>
                    <TextView android:id="@+id/tvFeeDichVu" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/item_house_fee_value_zero" android:textSize="14sp" android:textColor="@color/black" android:gravity="end"/>
                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="@color/outline"/>

            <!-- Footer actions -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp">

                <LinearLayout
                    android:id="@+id/llEditAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/item_house_edit_house"
                        android:textColor="@color/primary"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llRoomsAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/baseline_home_24"
                        app:tint="#2E7D32"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/item_house_room_list"
                        android:textColor="#2E7D32"
                        android:textSize="14sp"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnMore"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_more_vert"
                    app:tint="@color/text_sub"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>


