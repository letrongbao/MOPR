<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- UI section note -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_drawer_header"
            android:padding="16dp">

            <!-- Avatar tenant -->
            <FrameLayout
                android:id="@+id/avatarFrame"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_icon_circle_white">
                <TextView
                    android:id="@+id/tvInitial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/item_rental_history_initial_sample"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"/>
            </FrameLayout>

            <!-- UI section note -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/avatarFrame"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTenantName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_rental_history_tenant_name_sample"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/tvRoomInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_rental_history_room_info_sample"
                    android:textSize="13sp"
                    android:textColor="#DDFFFFFF"/>

            </LinearLayout>

            <!-- UI section note -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:background="@drawable/bg_card_rounded"
                android:backgroundTint="#40FFFFFF"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/item_rental_history_status_ended"
                android:textSize="11sp"
                android:textColor="@color/white"/>

        </RelativeLayout>

        <!-- UI section note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- UI section note -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/primary"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/item_rental_history_duration_label"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"/>

                    <TextView
                        android:id="@+id/tvRentalPeriod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/item_rental_history_period_sample"
                        android:textSize="14sp"
                        android:textColor="@color/text_main"
                        android:textStyle="bold"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_rounded"
                    android:backgroundTint="#E3F2FD"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="@string/item_rental_history_duration_sample"
                    android:textSize="12sp"
                    android:textColor="@color/primary"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="12dp"/>

            <!-- UI section note -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- UI section note -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- UI section note -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_phone"
                            app:tint="@color/text_sub"/>
                        <TextView
                            android:id="@+id/tvPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/item_rental_history_phone_sample"
                            android:textSize="13sp"
                            android:textColor="@color/text_main"/>
                    </LinearLayout>

                    <!-- CCCD -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_id_card"
                            app:tint="@color/text_sub"/>
                        <TextView
                            android:id="@+id/tvCccd"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/item_rental_history_id_sample"
                            android:textSize="13sp"
                            android:textColor="@color/text_main"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- UI section note -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <!-- UI section note -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/item_rental_history_rent_label"
                        android:textSize="11sp"
                        android:textColor="@color/text_sub"/>

                    <TextView
                        android:id="@+id/tvRentAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/item_rental_history_rent_sample"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"/>

                    <!-- UI section note -->
                    <TextView
                        android:id="@+id/tvDeposit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/item_rental_history_deposit_sample"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"/>

                </LinearLayout>

            </LinearLayout>

            <!-- UI section note -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <!-- UI section note -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_rounded"
                    android:backgroundTint="#FFF3E0"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_profile"
                        app:tint="#FF9800"/>

                    <TextView
                        android:id="@+id/tvMembers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/item_rental_history_members_sample"
                        android:textSize="11sp"
                        android:textColor="#FF9800"/>

                </LinearLayout>

                <!-- UI section note -->
                <LinearLayout
                    android:id="@+id/servicesContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:orientation="horizontal">
                    <!-- Dynamic service badges -->
                </LinearLayout>

            </LinearLayout>

            <!-- UI section note -->
            <LinearLayout
                android:id="@+id/noteContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_rounded"
                android:backgroundTint="#FAFAFA"
                android:padding="12dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_feedback"
                    app:tint="@color/text_sub"/>

                <TextView
                    android:id="@+id/tvNote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/item_rental_history_note_placeholder"
                    android:textSize="12sp"
                    android:textColor="@color/text_sub"
                    android:maxLines="2"
                    android:ellipsize="end"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

