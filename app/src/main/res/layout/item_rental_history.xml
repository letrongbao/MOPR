<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header với trạng thái -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_drawer_header"
            android:padding="16dp">

            <!-- Avatar tenant -->
            <FrameLayout
                android:id="@+id/avatarFrame"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_icon_circle_white">
                <TextView
                    android:id="@+id/tvInitial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="N"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"/>
            </FrameLayout>

            <!-- Tên và phòng -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/avatarFrame"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTenantName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nguyễn Văn A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/tvRoomInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phòng 101 - Nhà A"
                    android:textSize="13sp"
                    android:textColor="#DDFFFFFF"/>

            </LinearLayout>

            <!-- Badge kết thúc -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:background="@drawable/bg_card_rounded"
                android:backgroundTint="#40FFFFFF"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Đã kết thúc"
                android:textSize="11sp"
                android:textColor="@color/white"/>

        </RelativeLayout>

        <!-- Thông tin chi tiết -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Thời gian thuê -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/primary"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thời gian thuê"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"/>

                    <TextView
                        android:id="@+id/tvRentalPeriod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="01/01/2024 - 01/06/2024"
                        android:textSize="14sp"
                        android:textColor="@color/text_main"
                        android:textStyle="bold"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_rounded"
                    android:backgroundTint="#E3F2FD"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="6 tháng"
                    android:textSize="12sp"
                    android:textColor="@color/primary"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="12dp"/>

            <!-- Thông tin 2 cột -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Cột trái -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Số điện thoại -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_phone"
                            app:tint="@color/text_sub"/>
                        <TextView
                            android:id="@+id/tvPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="0987654321"
                            android:textSize="13sp"
                            android:textColor="@color/text_main"/>
                    </LinearLayout>

                    <!-- CCCD -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_id_card"
                            app:tint="@color/text_sub"/>
                        <TextView
                            android:id="@+id/tvCccd"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="012345678901"
                            android:textSize="13sp"
                            android:textColor="@color/text_main"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Cột phải -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <!-- Tiền phòng -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiền phòng"
                        android:textSize="11sp"
                        android:textColor="@color/text_sub"/>

                    <TextView
                        android:id="@+id/tvRentAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3,500,000đ"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"/>

                    <!-- Tiền cọc -->
                    <TextView
                        android:id="@+id/tvDeposit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cọc: 7,000,000đ"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Số thành viên và dịch vụ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <!-- Số thành viên -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_rounded"
                    android:backgroundTint="#FFF3E0"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_profile"
                        app:tint="#FF9800"/>

                    <TextView
                        android:id="@+id/tvMembers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="2 người"
                        android:textSize="11sp"
                        android:textColor="#FF9800"/>

                </LinearLayout>

                <!-- Dịch vụ -->
                <LinearLayout
                    android:id="@+id/servicesContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:orientation="horizontal">
                    <!-- Dynamic service badges -->
                </LinearLayout>

            </LinearLayout>

            <!-- Ghi chú nếu có -->
            <LinearLayout
                android:id="@+id/noteContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_rounded"
                android:backgroundTint="#FAFAFA"
                android:padding="12dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_feedback"
                    app:tint="@color/text_sub"/>

                <TextView
                    android:id="@+id/tvNote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Ghi chú..."
                    android:textSize="12sp"
                    android:textColor="@color/text_sub"
                    android:maxLines="2"
                    android:ellipsize="end"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
