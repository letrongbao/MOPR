<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/room" android:textStyle="bold" android:textColor="#212121"/>
        <Spinner android:id="@+id/spinnerPhong"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/month_year" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etThangNam"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="03/2026" android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/invoice_electric_section" android:textColor="@color/purple" android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/electric_start_reading" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etDienDau"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/electric_end_reading" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etDienCuoi"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/electric_unit_price" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etDonGiaDien"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="3500" android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/invoice_water_section" android:textColor="@color/purple" android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/water_start_reading" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etNuocDau"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/water_end_reading" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etNuocCuoi"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/water_unit_price" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etDonGiaNuoc"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="15000" android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/invoice_extra_fee_section" android:textColor="@color/purple" android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/fee_garbage" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etPhiRac"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/fee_wifi" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etPhiWifi"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/fee_parking" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etPhiGuiXe"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/invoice_total_estimated"
            android:textColor="#212121"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEstimatedTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/revenue_amount_zero"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
