<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Phòng" android:textStyle="bold" android:textColor="#212121"/>
        <Spinner android:id="@+id/spinnerPhong"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tháng / Năm" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etThangNam"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="03/2026" android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="── Điện ──" android:textColor="@color/purple" android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Chỉ số điện đầu kỳ" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etDienDau"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Chỉ số điện cuối kỳ" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etDienCuoi"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Đơn giá điện (đ/kWh)" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etDonGiaDien"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="3500" android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="── Nước ──" android:textColor="@color/purple" android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Chỉ số nước đầu kỳ" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etNuocDau"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Chỉ số nước cuối kỳ" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etNuocCuoi"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Đơn giá nước (đ/m³)" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etDonGiaNuoc"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="15000" android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="── Phụ phí ──" android:textColor="@color/purple" android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Phí rác (đ)" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etPhiRac"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Phí wifi (đ)" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etPhiWifi"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Phí gửi xe (đ)" android:textStyle="bold" android:textColor="#212121"/>
        <EditText android:id="@+id/etPhiGuiXe"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:inputType="numberDecimal"/>
    </LinearLayout>
</ScrollView>
