<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_money"
            app:tint="#FF6D00"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thu tiền cọc"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginStart="12dp"/>

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:contentDescription="Đóng"
            app:tint="#666666"/>
    </LinearLayout>

    <!-- Thông tin phòng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:padding="16dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tvPhongInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phòng 101"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvTenantInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Khách: Nguyễn Văn A - 0987654321"
            android:textSize="14sp"
            android:textColor="#555555"/>
    </LinearLayout>

    <!-- Số tiền cọc -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Số tiền cọc cần thu:"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvSoTienCoc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="500.000đ"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FF6D00"
        android:layout_marginBottom="24dp"/>

    <!-- Nút Gửi QR & Liên hệ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuiQR"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📲 Gửi QR &amp; Liên hệ"
        android:textSize="15sp"
        android:textColor="@color/white"
        android:layout_marginBottom="12dp"
        app:backgroundTint="#2196F3"
        app:cornerRadius="12dp"
        app:icon="@null"
        style="@style/Widget.MaterialComponents.Button"/>

    <!-- Nút Xác nhận đã thu -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnXacNhanDaThu"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="✅ Xác nhận đã thu cọc"
        android:textSize="15sp"
        android:textColor="@color/white"
        app:backgroundTint="#4CAF50"
        app:cornerRadius="12dp"
        app:icon="@null"
        style="@style/Widget.MaterialComponents.Button"/>

</LinearLayout>
