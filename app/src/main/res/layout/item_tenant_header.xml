<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="6dp">

    <!-- UI section note -->
    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_house"
        android:contentDescription="@string/room"
        android:layout_marginEnd="8dp"/>

    <!-- UI section note -->
    <TextView
        android:id="@+id/tvTenPhong"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/item_tenant_header_room_sample"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"/>

    <!-- UI section note -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTuNhap"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="@string/item_tenant_header_manual_input"
        android:textSize="11sp"
        android:textColor="#1565C0"
        android:paddingHorizontal="10dp"
        android:layout_marginEnd="6dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:strokeColor="#1565C0"
        app:strokeWidth="1dp"
        android:backgroundTint="@android:color/transparent"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <!-- UI section note -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnThem"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="@string/item_tenant_header_add"
        android:textSize="12sp"
        android:textColor="@android:color/white"
        android:paddingHorizontal="10dp"
        style="@style/Widget.MaterialComponents.Button"
        android:backgroundTint="#2E7D32"/>

</LinearLayout>


