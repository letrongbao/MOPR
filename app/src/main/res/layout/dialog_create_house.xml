<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/house_address_required_label"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/etHouseAddr"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/custome_edittext"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:hint="@string/house_address_hint"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/house_management_info"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/house_manager_name_required_label"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="8dp"/>

        <EditText
            android:id="@+id/etHouseName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/custome_edittext"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:hint="@string/house_manager_name_hint"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/house_manager_phone_required_label"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/etHousePhone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/custome_edittext"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:hint="@string/house_manager_phone_hint"
            android:inputType="phone"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/org_transfer_info_title"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/etChuTaiKhoan"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/custome_edittext"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:hint="@string/house_account_owner_hint"/>

        <EditText
            android:id="@+id/etNganHang"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/custome_edittext"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:hint="@string/house_bank_hint"/>

        <EditText
            android:id="@+id/etSoTaiKhoan"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/custome_edittext"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:hint="@string/bank_account_number_hint"
            android:inputType="number"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/house_fee_table_title"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"/>

        <!-- UI section note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">
            <EditText
                android:id="@+id/etGiaDien"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="@string/house_electricity_price_hint"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/unit_per_kwh"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- UI section note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaNuoc"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="@string/house_water_price_hint"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/house_water_method_note"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <RadioGroup
            android:id="@+id/rgNuoc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <RadioButton
                android:id="@+id/rbNuocNguoi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/water_by_person"
                android:textSize="13sp"/>
            <RadioButton
                android:id="@+id/rbNuocDongHo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/water_by_meter"
                android:textSize="13sp"/>
            <RadioButton
                android:id="@+id/rbNuocPhong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/water_by_room"
                android:textSize="13sp"
                android:checked="true"/>
        </RadioGroup>

        <!-- Xe -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">
            <EditText
                android:id="@+id/etGiaXe"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="@string/house_parking_price_hint"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/unit_per_vehicle"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Internet -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaInternet"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="@string/house_internet_price_hint"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/per_room"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- UI section note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaGiatSay"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="@string/house_laundry_price_hint"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/per_room"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- UI section note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaThangMay"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="@string/house_elevator_price_hint"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/per_room"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- UI section note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaTiviCap"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="@string/house_cable_tv_price_hint"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/per_room"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- UI section note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaRac"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="@string/house_garbage_price_hint"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/per_room"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- UI section note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaDichVu"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="@string/house_service_price_hint"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/per_room"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/house_add_other_fees"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddExtraFee"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:text="@string/house_add_fee"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="10dp"
            app:backgroundTint="@color/btn_orange"/>

        <LinearLayout
            android:id="@+id/llExtraFeesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/note_label"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/etHouseNote"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/custome_edittext"
            android:padding="12dp"
            android:gravity="top"
            android:textSize="13sp"
            android:hint="@string/house_note_invoice_hint"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/house_payment_code_label"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvQrStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/house_qr_not_added"
                android:textColor="#666666"
                android:textSize="12sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickQr"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/house_scan_code"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="10dp"
                app:backgroundTint="@color/btn_orange"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>





