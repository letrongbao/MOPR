<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F3F3">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitleLine1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hợp đồng"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvTitleLine2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card Nội dung hợp đồng -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E3E3E3"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số hợp đồng *"
                        android:textStyle="bold"
                        android:textColor="#212121"/>
                    <EditText
                        android:id="@+id/etSoHopDong"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_disabled"
                        android:enabled="false"
                        android:paddingHorizontal="14dp"
                        android:inputType="text"
                        android:textColor="#212121"/>

                    <!-- Tên và Điện thoại -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tên khách hàng *"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etTenKhach"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded"
                                android:paddingHorizontal="14dp"
                                android:inputType="textPersonName"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Điện thoại *"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etDienThoai"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded"
                                android:paddingHorizontal="14dp"
                                android:inputType="phone"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số CCCD *"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginTop="12dp"/>
                    <EditText
                        android:id="@+id/etCccd"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_rounded"
                        android:paddingHorizontal="14dp"
                        android:inputType="number"/>

                    <!-- Ảnh CCCD -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mặt trước CCCD"
                                    android:textColor="#666666"/>
                                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                                <ImageView
                                    android:id="@+id/ivEditFront"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/ic_edit"
                                    app:tint="#333333"/>
                            </LinearLayout>
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="120dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded">
                                <ImageView
                                    android:id="@+id/ivFront"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_id_card"
                                    app:tint="#8A8A8A"/>
                            </FrameLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mặt sau CCCD"
                                    android:textColor="#666666"/>
                                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                                <ImageView
                                    android:id="@+id/ivEditBack"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/ic_edit"
                                    app:tint="#333333"/>
                            </LinearLayout>
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="120dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded">
                                <ImageView
                                    android:id="@+id/ivBack"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_id_card"
                                    app:tint="#8A8A8A"/>
                            </FrameLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Phòng và Số người -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phòng *"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etPhong"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_disabled"
                                android:enabled="false"
                                android:paddingHorizontal="14dp"
                                android:inputType="text"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Số người ở *"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etSoNguoi"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded"
                                android:paddingHorizontal="14dp"
                                android:inputType="number"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Tiền phòng và Tiền cọc -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tiền phòng *"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etTienPhong"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_disabled"
                                android:enabled="false"
                                android:paddingHorizontal="14dp"
                                android:inputType="number"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tiền cọc"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etTienCoc"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded"
                                android:paddingHorizontal="14dp"
                                android:inputType="number"/>
                        </LinearLayout>
                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cbShowDeposit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Hiển thị tiền cọc trên hóa đơn"
                        android:checked="true"/>

                    <!-- Ngày ký và Số tháng -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ngày ký HĐ *"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp">
                                <EditText
                                    android:id="@+id/etNgayKy"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_input_rounded"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="48dp"
                                    android:hint="MM/yyyy"
                                    android:inputType="none"
                                    android:focusable="false"
                                    android:clickable="true"/>
                                <ImageView
                                    android:id="@+id/ivPickDate"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center_vertical|end"
                                    android:layout_marginEnd="14dp"
                                    android:src="@drawable/ic_calendar"
                                    app:tint="#333333"/>
                            </FrameLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Số tháng HĐ *"
                                android:textStyle="bold"
                                android:textColor="#212121"/>
                            <EditText
                                android:id="@+id/etSoThang"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_rounded"
                                android:paddingHorizontal="14dp"
                                android:inputType="number"/>
                        </LinearLayout>
                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/cbRemind"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Nhắc tôi trước 1 tháng khi HĐ hết hạn"
                        android:checked="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chỉ số điện ban đầu *"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginTop="12dp"/>
                    <EditText
                        android:id="@+id/etChiSoDien"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_rounded"
                        android:paddingHorizontal="14dp"
                        android:inputType="number"/>

                    <!-- Dịch vụ -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">
                        <CheckBox
                            android:id="@+id/cbGuiXe"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Gửi xe"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/llSoXe"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <LinearLayout
                            android:id="@+id/llSoXe"
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SL xe *"
                                android:textStyle="bold"
                                android:textColor="#212121"
                                android:layout_gravity="end"/>
                            <EditText
                                android:id="@+id/etSoXe"
                                android:layout_width="match_parent"
                                android:layout_height="46dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_input_disabled"
                                android:enabled="false"
                                android:paddingHorizontal="14dp"
                                android:inputType="number"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvGuiXePrice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Gửi xe 0 đ/chiếc"
                            android:textColor="#212121"
                            app:layout_constraintStart_toStartOf="@id/cbGuiXe"
                            app:layout_constraintTop_toBottomOf="@id/cbGuiXe"
                            app:layout_constraintEnd_toStartOf="@id/llSoXe"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <CheckBox
                        android:id="@+id/cbInternet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Internet 0 đ/phòng"
                        android:textStyle="bold"/>

                    <CheckBox
                        android:id="@+id/cbGiatSay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Giặt sấy 0 đ/phòng"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ghi chú"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginTop="12dp"/>
                    <EditText
                        android:id="@+id/etGhiChu"
                        android:layout_width="match_parent"
                        android:layout_height="110dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_rounded"
                        android:padding="14dp"
                        android:gravity="top"
                        android:inputType="textMultiLine"/>

                    <CheckBox
                        android:id="@+id/cbShowNote"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Hiển thị ghi chú trên hóa đơn"
                        android:checked="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nhắc báo phí vào"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginTop="12dp"/>

                    <RadioGroup
                        android:id="@+id/rgBillingReminder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbRemindStartMonth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Đầu tháng"/>

                        <RadioButton
                            android:id="@+id/rbRemindMidMonth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Giữa tháng"/>

                        <RadioButton
                            android:id="@+id/rbRemindEndMonth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Cuối tháng"/>
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Nút bấm -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:text="Tạo hợp đồng"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="10dp"
                app:backgroundTint="#1976D2"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrint"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="In hợp đồng"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:visibility="gone"
                app:cornerRadius="10dp"
                app:backgroundTint="#1976D2"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnd"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="Kết thúc hợp đồng"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:visibility="gone"
                app:cornerRadius="10dp"
                app:backgroundTint="#D32F2F"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="Cập nhật hợp đồng"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:visibility="gone"
                app:cornerRadius="10dp"
                app:backgroundTint="#1976D2"/>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
