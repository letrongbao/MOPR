<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên quản lý *"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"/>

        <EditText
            android:id="@+id/etKhuName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/custome_edittext"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:hint="Nhập tên quản lý"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Số điện thoại *"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/etKhuPhone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/custome_edittext"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:hint="Nhập SĐT quản lý"
            android:inputType="phone"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Địa chỉ căn nhà *"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/etKhuAddr"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/custome_edittext"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:hint="Nhập địa chỉ"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thông tin chuyển khoản"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/etChuTaiKhoan"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/custome_edittext"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:hint="Chủ TK"/>

        <EditText
            android:id="@+id/etNganHang"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/custome_edittext"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:hint="Ngân hàng"/>

        <EditText
            android:id="@+id/etSoTaiKhoan"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/custome_edittext"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:hint="Số tài khoản"
            android:inputType="number"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bảng giá phí"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"/>

        <!-- Điện -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">
            <EditText
                android:id="@+id/etGiaDien"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="Giá điện"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / KWH"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Nước -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaNuoc"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="Giá nước"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" (xem chọn dưới)"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <RadioGroup
            android:id="@+id/rgNuoc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <RadioButton
                android:id="@+id/rbNuocNguoi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tính theo người"
                android:textSize="13sp"/>
            <RadioButton
                android:id="@+id/rbNuocDongHo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tính theo đồng hồ"
                android:textSize="13sp"/>
            <RadioButton
                android:id="@+id/rbNuocPhong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tính theo phòng"
                android:textSize="13sp"
                android:checked="true"/>
        </RadioGroup>

        <!-- Xe -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">
            <EditText
                android:id="@+id/etGiaXe"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="Giá xe"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / chiếc"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Internet -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaInternet"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="Giá internet"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / phòng"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Giặt sấy -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaGiatSay"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="Giá giặt sấy"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / phòng"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Thang máy -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaThangMay"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="Giá thang máy"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / phòng"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Tivi cáp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaTiviCap"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="Giá tivi cáp"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / phòng"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Rác -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaRac"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="Giá rác"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / phòng"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Dịch vụ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etGiaDichVu"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/custome_edittext"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:hint="Giá dịch vụ"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / phòng"
                android:textSize="13sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thêm các phí khác"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddExtraFee"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:text="Thêm phí"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="10dp"
            app:backgroundTint="@color/btn_orange"/>

        <LinearLayout
            android:id="@+id/llExtraFeesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ghi chú"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/etKhuNote"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/custome_edittext"
            android:padding="12dp"
            android:gravity="top"
            android:textSize="13sp"
            android:hint="Ghi chú (hiển thị trên hóa đơn)"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mã thanh toán"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvQrStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="(Chưa thêm mã)"
                android:textColor="#666666"
                android:textSize="12sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickQr"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Quét mã"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="10dp"
                app:backgroundTint="@color/btn_orange"/>
        </LinearLayout>

        <RadioGroup
            android:id="@+id/rgRemindFee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbRemindStartMonth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nhắc báo phí vào đầu tháng"/>

            <RadioButton
                android:id="@+id/rbRemindEndMonth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nhắc báo phí vào cuối tháng"/>
        </RadioGroup>

    </LinearLayout>
</ScrollView>