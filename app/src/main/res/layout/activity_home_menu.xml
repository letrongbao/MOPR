<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:openDrawer="end">

    <!-- Nội dung chính -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:fitsSystemWindows="false">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_drawer_header"
            android:fitsSystemWindows="true"
            app:elevation="0dp">

            <RelativeLayout
                android:id="@+id/appBar"
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:paddingHorizontal="16dp">

                <!-- Logo App -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_circle"
                        android:layout_marginEnd="10dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/baseline_home_24"
                            app:tint="@color/white"/>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvAppTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUẢN LÝ TRỌ"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:letterSpacing="0.03"/>
                </LinearLayout>

                <!-- Icon Người dùng -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/btnProfile"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="#26FFFFFF"
                    android:padding="8dp"
                    android:src="@drawable/ic_profile"
                    android:contentDescription="Tài khoản"
                    app:tint="@color/white"
                    app:shapeAppearanceOverlay="@style/CircleImage" />

            </RelativeLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F8F9FA"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Thanh thông tin tóm tắt (Dashboard) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="14dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F5FAFF"
                    app:strokeWidth="1dp"
                    app:strokeColor="#D7E7F7">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:minHeight="108dp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvTotalHouses"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/primary"
                                android:textSize="28sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Căn nhà"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#4A6582"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="38dp" android:background="#D7E7F7" android:layout_gravity="center"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvVacantRooms"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/status_empty"
                                android:textSize="28sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phòng trống"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#4A6582"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="38dp" android:background="#D7E7F7" android:layout_gravity="center"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvRentedRooms"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/status_rented"
                                android:textSize="28sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Đang thuê"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#4A6582"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Sử dụng View thay cho GridView bên trong ScrollView để tránh lỗi cuộn -->
                <!-- Menu Grid 2x2 với thiết kế mới -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="16dp">

                    <!-- Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Card 1: Quản lý nhà phòng -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardHouse"
                            android:layout_width="0dp"
                            android:layout_height="168dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_card_gradient_purple"
                                android:padding="16dp">

                                <!-- Decorative circle -->
                                <View
                                    android:layout_width="100dp"
                                    android:layout_height="100dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_alignParentTop="true"
                                    android:layout_marginEnd="-30dp"
                                    android:layout_marginTop="-30dp"
                                    android:background="@drawable/bg_icon_circle"
                                    android:backgroundTint="#20FFFFFF"
                                    android:alpha="0.5"/>

                                <ImageView
                                    android:id="@+id/iconHouse"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:layout_alignParentTop="true"
                                    android:src="@drawable/ic_house"
                                    app:tint="@color/white"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentBottom="true"
                                    android:text="Quản lý\nnhà phòng"
                                    android:textColor="@color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:lineSpacingExtra="2dp"/>

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_alignParentBottom="true"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="#80FFFFFF"/>

                            </RelativeLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Card 2: Báo phí / Hóa đơn -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardInvoice"
                            android:layout_width="0dp"
                            android:layout_height="168dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_card_gradient_pink"
                                android:padding="16dp">

                                <!-- Decorative circle -->
                                <View
                                    android:layout_width="80dp"
                                    android:layout_height="80dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_alignParentTop="true"
                                    android:layout_marginEnd="-20dp"
                                    android:layout_marginTop="-20dp"
                                    android:background="@drawable/bg_icon_circle"
                                    android:backgroundTint="#20FFFFFF"
                                    android:alpha="0.5"/>

                                <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:layout_alignParentTop="true"
                                    android:src="@drawable/ic_invoice"
                                    app:tint="@color/white"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentBottom="true"
                                    android:text="Báo phí\nhóa đơn"
                                    android:textColor="@color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:lineSpacingExtra="2dp"/>

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_alignParentBottom="true"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="#80FFFFFF"/>

                            </RelativeLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <!-- Card 3: Quản lý chi -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardExpense"
                            android:layout_width="0dp"
                            android:layout_height="168dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_card_gradient_blue"
                                android:padding="16dp">

                                <!-- Decorative circle -->
                                <View
                                    android:layout_width="90dp"
                                    android:layout_height="90dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_alignParentTop="true"
                                    android:layout_marginEnd="-25dp"
                                    android:layout_marginTop="-25dp"
                                    android:background="@drawable/bg_icon_circle"
                                    android:backgroundTint="#20FFFFFF"
                                    android:alpha="0.5"/>

                                <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:layout_alignParentTop="true"
                                    android:src="@drawable/ic_expense"
                                    app:tint="@color/white"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentBottom="true"
                                    android:text="Quản lý\nchi phí"
                                    android:textColor="@color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:lineSpacingExtra="2dp"/>

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_alignParentBottom="true"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="#80FFFFFF"/>

                            </RelativeLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Card 4: Báo cáo -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardReport"
                            android:layout_width="0dp"
                            android:layout_height="168dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_card_gradient_green"
                                android:padding="16dp">

                                <!-- Decorative circle -->
                                <View
                                    android:layout_width="70dp"
                                    android:layout_height="70dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_alignParentTop="true"
                                    android:layout_marginEnd="-15dp"
                                    android:layout_marginTop="-15dp"
                                    android:background="@drawable/bg_icon_circle"
                                    android:backgroundTint="#20FFFFFF"
                                    android:alpha="0.5"/>

                                <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:layout_alignParentTop="true"
                                    android:src="@drawable/ic_report"
                                    app:tint="@color/white"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentBottom="true"
                                    android:text="Thống kê\nbáo cáo"
                                    android:textColor="@color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:lineSpacingExtra="2dp"/>

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_alignParentBottom="true"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="#80FFFFFF"/>

                            </RelativeLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Profile Drawer (trượt từ phải) -->
    <LinearLayout
        android:id="@+id/profileDrawer"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="@color/white"
        android:fitsSystemWindows="false"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:elevation="8dp">

        <!-- Header với gradient -->
        <RelativeLayout
            android:id="@+id/drawerHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_drawer_header"
            android:paddingTop="48dp"
            android:paddingBottom="24dp"
            android:paddingHorizontal="20dp">

            <!-- Logo app nhỏ ở góc trên -->
            <LinearLayout
                android:id="@+id/logoContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <FrameLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_icon_circle_white">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/baseline_home_24"
                        app:tint="@color/primary"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="QUẢN LÝ TRỌ"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>
            </LinearLayout>

            <!-- Avatar người dùng -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/drawerAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_below="@id/logoContainer"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="8dp"
                android:src="@drawable/ic_profile"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="@color/white"
                app:strokeWidth="2dp"/>

            <!-- Tên người dùng -->
            <TextView
                android:id="@+id/drawerUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/drawerAvatar"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="12dp"
                android:text="Người dùng"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- Email -->
            <TextView
                android:id="@+id/drawerUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/drawerUserName"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="4dp"
                android:text="email@example.com"
                android:textColor="#DDFFFFFF"
                android:textSize="13sp"/>

        </RelativeLayout>

        <!-- Menu chức năng -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingVertical="12dp">

            <!-- Sửa thông tin -->
            <LinearLayout
                android:id="@+id/menuEditProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_menu_item_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="#E3F2FD">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/primary"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sửa thông tin"
                        android:textColor="@color/text_main"
                        android:textSize="15sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cập nhật họ tên, số điện thoại"
                        android:textColor="@color/text_sub"
                        android:textSize="12sp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#BDBDBD"/>
            </LinearLayout>

            <!-- Lịch sử cho thuê -->
            <LinearLayout
                android:id="@+id/menuRentalHistory"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_menu_item_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="#F3E5F5">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_history"
                        app:tint="#9C27B0"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lịch sử cho thuê"
                        android:textColor="@color/text_main"
                        android:textSize="15sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xem lại các hợp đồng đã hoàn thành"
                        android:textColor="@color/text_sub"
                        android:textSize="12sp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#BDBDBD"/>
            </LinearLayout>

            <!-- Đổi mật khẩu -->
            <LinearLayout
                android:id="@+id/menuChangePassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_menu_item_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="#FFF3E0">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_lock"
                        app:tint="#FF9800"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đổi mật khẩu"
                        android:textColor="@color/text_main"
                        android:textSize="15sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thay đổi mật khẩu đăng nhập"
                        android:textColor="@color/text_sub"
                        android:textSize="12sp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#BDBDBD"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Footer - Góp ý, Chia sẻ, Đăng xuất -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FAFAFA">

            <!-- Góp ý và Chia sẻ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Liên hệ góp ý -->
                <LinearLayout
                    android:id="@+id/menuFeedback"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_menu_item_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="#E8F5E9">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_feedback"
                            app:tint="#4CAF50"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Liên hệ góp ý"
                        android:textColor="@color/text_main"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Chia sẻ ứng dụng -->
                <LinearLayout
                    android:id="@+id/menuShare"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_menu_item_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_circle"
                        android:backgroundTint="#E3F2FD">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_share"
                            app:tint="@color/primary"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Chia sẻ app"
                        android:textColor="@color/text_main"
                        android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#EEEEEE"/>

            <!-- Đăng xuất -->
            <LinearLayout
                android:id="@+id/menuLogout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_menu_item_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_logout"
                    app:tint="#F44336"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Đăng xuất"
                    android:textColor="#F44336"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Version -->
            <TextView
                android:id="@+id/tvDrawerVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Phiên bản 2.6.3"
                android:textSize="11sp"
                android:textColor="#BDBDBD"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
