<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Diagonal status ribbon -->
            <TextView
                android:id="@+id/tvRibbonStatus"
                android:layout_width="80dp"
                android:layout_height="20dp"
                android:background="#FFEB3B"
                android:text="@string/item_invoice_status_unreported"
                android:textSize="9sp"
                android:textColor="#333333"
                android:gravity="center"
                android:rotation="-45"
                android:layout_marginStart="-25dp"
                android:layout_marginTop="5dp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp">

                <!-- Room number -->
                <TextView
                    android:id="@+id/tvPhong"
                    android:layout_width="80dp"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="@string/item_invoice_room_sample"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginEnd="12dp"/>

                <!-- Details -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Link to view reported fees (red underlined) -->
                    <TextView
                        android:id="@+id/tvViewReportedFees"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/item_invoice_view_reported_fees"
                        android:textSize="12sp"
                        android:textColor="#D32F2F"
                        android:textStyle="italic"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingVertical="4dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#D32F2F"
                        android:layout_marginBottom="8dp"/>

                    <!-- Tenant info -->
                    <TextView
                        android:id="@+id/tvTenantName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/item_invoice_tenant_info_sample"
                        android:textSize="12sp"
                        android:textColor="#333333"/>

                    <TextView
                        android:id="@+id/tvPriceMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/item_invoice_price_month_sample"
                        android:textSize="12sp"
                        android:textColor="#555555"/>

                    <TextView
                        android:id="@+id/tvReportDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/item_invoice_month_sample"
                        android:textSize="12sp"
                        android:textColor="#555555"/>

                    <!-- Main action button (changes based on tab) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMainAction"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/item_invoice_action_report_fee"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="6dp"
                        app:backgroundTint="#7B1FA2"
                        android:minHeight="0dp"/>

                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>