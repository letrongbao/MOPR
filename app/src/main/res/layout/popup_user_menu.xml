<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- ===== HEADER xanh dương ===== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_drawer_header"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- Avatar -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/popupAvatar"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_centerHorizontal="true"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/white"
            app:strokeWidth="2dp" />

        <!-- Tên người dùng -->
        <TextView
            android:id="@+id/popupUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/popupAvatar"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:text="@string/profile_display_name_placeholder"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <!-- Email -->
        <TextView
            android:id="@+id/popupUserEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/popupUserName"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="4dp"
            android:text="@string/profile_email_placeholder"
            android:textColor="#DDFFFFFF"
            android:textSize="13sp" />

    </RelativeLayout>

    <!-- ===== DANH SÁCH MỤC MENU ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <!-- Quản lý tài khoản -->
        <LinearLayout
            android:id="@+id/popupMenuEditProfile"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_menu_item_ripple"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_circle"
                android:backgroundTint="#E3F2FD">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/primary" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/profile_manage_account_title"
                android:textColor="@color/text_main"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Đổi mật khẩu -->
        <LinearLayout
            android:id="@+id/popupMenuChangePassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_menu_item_ripple"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_circle"
                android:backgroundTint="#FFF3E0">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lock"
                    app:tint="#FF9800" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/change_password"
                android:textColor="@color/text_main"
                android:textSize="15sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ===== DIVIDER ===== -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginHorizontal="16dp" />

    <!-- ===== FOOTER: NÚT ĐĂNG XUẤT ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/popupMenuLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_menu_item_ripple"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_logout"
                app:tint="#F44336" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/logout"
                android:textColor="#F44336"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/app_version_label"
            android:textColor="#BDBDBD"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>
