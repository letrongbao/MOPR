rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isTenantMember(tenantId) {
      return signedIn() && exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }

    function uidIsTenantMember(tenantId, uid) {
      return uid is string
        && exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(uid));
    }

    function memberRole(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)).data.role;
    }

    function invitePath(tenantId, code) {
      return /databases/$(database)/documents/tenants/$(tenantId)/invites/$(code);
    }

    function validInvite(tenantId, code) {
      return signedIn()
        && request.auth.token.email != null
        && exists(invitePath(tenantId, code))
        && get(invitePath(tenantId, code)).data.email == request.auth.token.email
        && get(invitePath(tenantId, code)).data.status == 'PENDING';
    }

    function isOwner(tenantId) {
      return isTenantMember(tenantId) && memberRole(tenantId) == 'OWNER';
    }

    function isStaffOrOwner(tenantId) {
      return isTenantMember(tenantId) && (memberRole(tenantId) in ['OWNER', 'STAFF']);
    }

    match /users/{userId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;

      // Legacy subcollections (per-user scope) - kept for backward compatibility & migration.
      match /{col}/{docId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    match /tenants/{tenantId} {
      allow read: if isTenantMember(tenantId);
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;

      // OWNER can update only basic org config + quota knobs
      allow update: if isOwner(tenantId)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'name',
          'timezone',
          'currency',
          'billingCycleDay',
          'plan',
          'maxRooms',
          'maxStaff',
          'maxInvoicesPerMonth',
          'bankCode',
          'bankAccountNo',
          'bankAccountName',
          'updatedAt'
        ]);

      allow delete: if false;

      match /members/{memberId} {
        allow read: if isTenantMember(tenantId);

        // create OWNER membership sau khi tenant đã tồn tại, hoặc STAFF/TENANT khi có invite hợp lệ
        allow create: if signedIn()
          && request.auth.uid == memberId
          && (
            (
              request.resource.data.role == 'OWNER'
              && get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerUid == request.auth.uid
            )
            || (
              (request.resource.data.role in ['STAFF', 'TENANT'])
              && request.resource.data.inviteCode is string
              && validInvite(tenantId, request.resource.data.inviteCode)
            )
          );

        allow update: if isOwner(tenantId);
        allow delete: if false;
      }

      match /invites/{inviteId} {
        allow read: if isOwner(tenantId) || (signedIn() && request.auth.token.email != null && request.auth.token.email == resource.data.email);
        allow create: if isOwner(tenantId);
        // invitee chỉ được update khi invite đang PENDING (accept), owner được update mọi lúc
        allow update: if isOwner(tenantId) || (
          signedIn()
          && request.auth.token.email != null
          && request.auth.token.email == resource.data.email
          && resource.data.status == 'PENDING'
        );
        allow delete: if false;
      }

      match /auditLogs/{logId} {
        allow read: if isStaffOrOwner(tenantId);
        allow create: if isStaffOrOwner(tenantId);
        allow update, delete: if false;
      }

      function memberRoomId(tenantId) {
        return get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)).data.roomId;
      }

      match /houses/{docId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isStaffOrOwner(tenantId);
      }

      match /rooms/{docId} {
        allow read: if isStaffOrOwner(tenantId)
          || (isTenantMember(tenantId) && memberRole(tenantId) == 'TENANT' && docId == memberRoomId(tenantId));
        allow write: if isStaffOrOwner(tenantId);
      }

      match /contracts/{docId} {
        allow read: if isStaffOrOwner(tenantId)
          || (isTenantMember(tenantId) && memberRole(tenantId) == 'TENANT' && resource.data.roomId == memberRoomId(tenantId));
        allow write: if isStaffOrOwner(tenantId);
      }

      match /contractMembers/{docId} {
        allow read: if isStaffOrOwner(tenantId)
          || (isTenantMember(tenantId) && memberRole(tenantId) == 'TENANT' && resource.data.roomId == memberRoomId(tenantId));
        allow write: if isStaffOrOwner(tenantId);
      }

      match /invoices/{docId} {
        allow read: if isStaffOrOwner(tenantId)
          || (isTenantMember(tenantId) && memberRole(tenantId) == 'TENANT' && resource.data.roomId == memberRoomId(tenantId));
        allow write: if isStaffOrOwner(tenantId);
      }

      match /expenses/{docId} {
        allow read: if isStaffOrOwner(tenantId);
        allow write: if isStaffOrOwner(tenantId);
      }

      match /rentalHistory/{docId} {
        allow read: if isStaffOrOwner(tenantId)
          || (isTenantMember(tenantId) && memberRole(tenantId) == 'TENANT' && resource.data.roomId == memberRoomId(tenantId));
        allow write: if isStaffOrOwner(tenantId);
      }

      match /backups/{docId} {
        allow read, write: if isStaffOrOwner(tenantId);
      }

      match /meterReadings/{docId} {
        allow read: if isStaffOrOwner(tenantId)
          || (isTenantMember(tenantId) && memberRole(tenantId) == 'TENANT' && resource.data.roomId == memberRoomId(tenantId));

        allow create, delete: if isStaffOrOwner(tenantId);

        allow update: if isStaffOrOwner(tenantId) || (
          isTenantMember(tenantId)
          && memberRole(tenantId) == 'TENANT'
          && resource.data.roomId == memberRoomId(tenantId)
          && request.resource.data.roomId == resource.data.roomId
          && request.resource.data.periodKey == resource.data.periodKey
          && request.resource.data.elecStart == resource.data.elecStart
          && request.resource.data.elecEnd == resource.data.elecEnd
          && request.resource.data.waterStart == resource.data.waterStart
          && request.resource.data.waterEnd == resource.data.waterEnd
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'tenantConfirmStatus',
            'tenantConfirmNote',
            'tenantConfirmAt'
          ])
          && (request.resource.data.tenantConfirmStatus in ['APPROVED', 'DISPUTED'])
        );
      }

      match /payments/{docId} {
        allow read: if isStaffOrOwner(tenantId)
          || (isTenantMember(tenantId) && memberRole(tenantId) == 'TENANT' && resource.data.roomId == memberRoomId(tenantId));
        allow write: if isStaffOrOwner(tenantId);
      }

      match /tickets/{docId} {
        allow read: if isStaffOrOwner(tenantId)
          || (isTenantMember(tenantId) && memberRole(tenantId) == 'TENANT' && resource.data.roomId == memberRoomId(tenantId));

        allow create: if isStaffOrOwner(tenantId) || (
          isTenantMember(tenantId)
          && memberRole(tenantId) == 'TENANT'
          && request.resource.data.roomId == memberRoomId(tenantId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.status == 'OPEN'
        );

        // Tenant can update only when ticket is OPEN and status is not changed.
        allow update: if isStaffOrOwner(tenantId) || (
          isTenantMember(tenantId)
          && memberRole(tenantId) == 'TENANT'
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.roomId == resource.data.roomId
          && request.resource.data.createdAt == resource.data.createdAt
          && (
            // Tenant can edit own OPEN ticket content without changing status
            (
              resource.data.status == 'OPEN'
              && request.resource.data.status == 'OPEN'
              && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'title',
                'description',
                'updatedAt'
              ])
            )
            ||
            // Tenant can resubmit rejected ticket: REJECTED -> OPEN and clear rejectReason
            (
              resource.data.status == 'REJECTED'
              && request.resource.data.status == 'OPEN'
              && request.resource.data.rejectReason == null
              && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'title',
                'description',
                'status',
                'rejectReason',
                'updatedAt'
              ])
            )
          )
        );

        allow delete: if isStaffOrOwner(tenantId);
      }

      match /chat_conversations/{docId} {
        allow read: if isTenantMember(tenantId)
          && request.auth.uid in resource.data.participantIds;

        allow create: if isTenantMember(tenantId)
          && request.auth.uid in request.resource.data.participantIds
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.type in ['HOUSE', 'ROOM', 'PRIVATE']
          && request.resource.data.participantIds is list
          && request.resource.data.participantIds.size() >= 2
          && (
            (
              request.resource.data.type == 'PRIVATE'
              && request.resource.data.roomId == null
              && request.resource.data.participantIds.size() == 2
            )
            || (
              request.resource.data.type == 'ROOM'
              && request.resource.data.roomId is string
              && request.resource.data.roomId.size() > 0
            )
            || (
              request.resource.data.type == 'HOUSE'
              && request.resource.data.roomId == null
            )
          );

        allow update: if isTenantMember(tenantId)
          && request.auth.uid in resource.data.participantIds
          && request.auth.uid in request.resource.data.participantIds
          && request.resource.data.type == resource.data.type
          && request.resource.data.roomId == resource.data.roomId
          && request.resource.data.participantIds == resource.data.participantIds
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'displayName',
            'updatedAt',
            'lastMessage',
            'lastSenderId',
            'lastMessageAt'
          ]);

        allow delete: if false;

        match /messages/{messageId} {
          allow read: if isTenantMember(tenantId)
            && request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)/chat_conversations/$(docId)).data.participantIds;

          allow create: if isTenantMember(tenantId)
            && request.auth.uid == request.resource.data.senderId
            && request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)/chat_conversations/$(docId)).data.participantIds
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 1000;

          allow update, delete: if false;
        }
      }

      match /notifications/{docId} {
        allow read: if isTenantMember(tenantId)
          && (
            isStaffOrOwner(tenantId)
            || resource.data.userId == request.auth.uid
          );

        allow create: if isTenantMember(tenantId)
          && request.resource.data.senderId == request.auth.uid
          && uidIsTenantMember(tenantId, request.resource.data.userId);

        allow update: if isTenantMember(tenantId)
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.type == resource.data.type
          && request.resource.data.conversationId == resource.data.conversationId
          && request.resource.data.body == resource.data.body
          && request.resource.data.title == resource.data.title
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'isRead',
            'readAt'
          ]);

        allow delete: if false;
      }

      // default deny for unknown subcollections (tighten-by-default)
      match /{document=**} {
        allow read, write: if false;
      }
    }
  }
}
